PORT=8000
CORS_ORIGIN=http://localhost:5173
# Use either MONGODB_URI or MONGODB_URL. For Atlas use the full connection string (without real credentials):
MONGODB_URL=mongodb+srv://<username>:<password>@cluster0.example.mongodb.net/<dbname>

# token secret (replace with secure random values in your real .env)
ACCESS_TOKEN_SECRET=your_access_token_secret_here
REFRESH_TOKEN_SECRET=your_refresh_token_secret_here

# token expiration times
ACCESS_TOKEN_EXPIRATION=1d
REFRESH_TOKEN_EXPIRATION=7d
