# Optional global override. If set, it is used for every environment.
# VITE_API_BASE=https://fitcek.onrender.com/api/v1

# Used when running locally on localhost/IP in browser dev.
VITE_API_BASE_DEV=http://localhost:8000/api/v1

# Used in production web and native APK builds by default.
VITE_API_BASE_PROD=https://fitcek.onrender.com/api/v1

# Optional native override for Android/iOS builds.
# For Android emulator + local backend, use: http://10.0.2.2:8000/api/v1
# For physical device, use your machine LAN IP e.g. http://192.168.1.20:8000/api/v1
# VITE_API_BASE_NATIVE=http://10.0.2.2:8000/api/v1
